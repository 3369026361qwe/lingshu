# === 灵枢量化系统 环境变量 ===

# LLM 配置
LLM_BACKEND=deepseek          # deepseek | qwen | openai
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 数据源
TUSHARE_TOKEN=your_tushare_token_here

# 数据库
DATABASE_URL=sqlite:///./data/lingshu.db          # 开发环境
# DATABASE_URL=postgresql://user:pass@localhost:5432/lingshu  # 生产环境

# Redis (可选，不设置则自动使用内存缓存降级)
REDIS_URL=redis://localhost:6379/0

# 服务
API_HOST=0.0.0.0
API_PORT=8000

# 调试
DB_ECHO=0
